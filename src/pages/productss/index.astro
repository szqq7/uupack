---
import { getEmDashCollection, getEmDashEntry } from "emdash";
import Base from "../../layouts/Base.astro";

const { entries } = await getEmDashCollection("productss");
const rawProducts = entries || [];

// 用 getEmDashEntry 获取每个产品的完整数据（含自定义字段）
// 已知事实：链路 ① terms.product 是空数组，所以改走链路 ② category_slugs
const products = await Promise.all(
  rawProducts.map(async (p) => {
    const full = await getEmDashEntry("productss", p.slug);

    // 解析 category_slugs：可能是 JSON 字符串，也可能已经是数组
    let catSlugs: string[] = [];
    try {
      const raw = full?.data?.category_slugs;
      if (raw) {
        const parsed = typeof raw === "string" ? JSON.parse(raw) : raw;
        catSlugs = Array.isArray(parsed) ? parsed : [];
      }
    } catch { /* ignore */ }

    return {
      ...p,
      _termSlugs: full?.terms?.product || [],  // 空数组，仅作调试对比
      _catSlugs: catSlugs,                      // 真正用于过滤的字段
    };
  })
);

const debugFirst = products[0];

const url = new URL(Astro.request.url);
const selectedCategory = url.searchParams.get("category");

// 过滤：用 category_slugs
const filteredProducts = selectedCategory
  ? products.filter((p) => {
      const slugs = p._catSlugs || [];
      return slugs.includes(selectedCategory);
    })
  : products;

const displayProducts = filteredProducts.slice(0, 12);

function getFirstImage(entry) {
  try {
    if (!entry?.data?.picture_json) return "";
    const raw = typeof entry.data.picture_json === "string"
      ? entry.data.picture_json : JSON.stringify(entry.data.picture_json);
    if (!raw || raw === "null" || raw === "{}") return "";
    const parsed = JSON.parse(raw);
    const pics = Array.isArray(parsed) ? parsed : [parsed];
    return pics[0]?.url || pics[0]?.src || pics[0] || "";
  } catch { return ""; }
}
---

<Base title="Products">
  <!-- 调试面板：显示 _catSlugs 原始值和过滤结果 -->
  <div style="background:#ffe0b0;padding:10px;font-size:11px;font-family:monospace;margin-bottom:1rem;">
    <strong>DEBUG:</strong>
    | selected=<b>{selectedCategory || "(none)"}</b>
    | total=<b>{products.length}</b>
    | filtered=<b>{filteredProducts.length}</b><br>
    <strong>sample _catSlugs:</strong> <code>{JSON.stringify(debugFirst?._catSlugs)}</code><br>
    <strong>sample _termSlugs:</strong> <code>{JSON.stringify(debugFirst?._termSlugs)}</code><br>
    <strong>sample title:</strong> <code>{debugFirst?.data?.title}</code>
  </div>

  <div class="products-page">
    <header class="products-header">
      <h1 class="page-title">Products</h1>
      <p class="page-subtitle">
        {selectedCategory ? "已筛选: " + selectedCategory + " (" + filteredProducts.length + ")" : "共 " + products.length + " 个产品"}
      </p>
    </header>

    <div class="products-grid">
      {displayProducts.map((product) => {
        const imgUrl = getFirstImage(product);
        return (
          <a href={`/productss/${product.slug}`} class="product-card">
            <div class="product-image">
              {imgUrl ? (
                <img src={imgUrl} alt={product.data?.title || ""} loading="lazy" />
              ) : (
                <div class="no-image">No Image</div>
              )}
            </div>
            <h3 class="product-title">{product.data?.title}</h3>
          </a>
        );
      })}
    </div>

    {displayProducts.length === 0 && (
      <div class="empty-state">
        <p>{selectedCategory ? "此分类下暂无产品" : "暂无产品"}</p>
      </div>
    )}
  </div>
</Base>

<style>
  .products-page { max-width: 1400px; margin: 0 auto; padding: 2rem; }
  .products-header { text-align: center; margin-bottom: 2.5rem; }
  .page-title { font-size: 1.75rem; font-weight: 700; color: #222; margin-bottom: 0.25rem; }
  .page-subtitle { font-size: 0.95rem; color: #888; }
  .products-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem; }
  .product-card { text-decoration: none; color: inherit; transition: transform 0.2s, box-shadow 0.2s; border-radius: 8px; overflow: hidden; background: #fff; border: 1px solid #f0f0f0; }
  .product-card:hover { transform: translateY(-4px); box-shadow: 0 8px 24px rgba(0,0,0,0.08); }
  .product-image { aspect-ratio: 1; background: #f8f9fa; overflow: hidden; display: flex; align-items: center; justify-content: center; }
  .product-image img { width: 100%; height: 100%; object-fit: contain; padding: 1rem; transition: transform 0.3s; }
  .product-card:hover .product-image img { transform: scale(1.03); }
  .no-image { color: #bbb; font-size: 0.9rem; }
  .product-title { font-size: 0.9rem; font-weight: 500; line-height: 1.4; color: #333; padding: 0.75rem; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; min-height: 3.2em; }
  .empty-state { text-align: center; padding: 5rem 2rem; color: #999; }
  @media (max-width: 1200px) { .products-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 900px) { .products-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 500px) { .products-grid { grid-template-columns: repeat(2, 1fr); gap: 1rem; } }
</style>
