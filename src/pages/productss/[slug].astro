---
import { getEmDashEntry } from "emdash";
import Base from "../../layouts/Base.astro";

const { entry, cacheHint } = await getEmDashEntry("productss", Astro.params.slug);
if (!entry) return Astro.redirect("/404");
if (Astro.cache?.enabled) Astro.cache.set(cacheHint);

const data = entry.data || {};
const title = data.title || "Product";
const spu = data.spu || "";

// picture_json
let pictures: Array<{url: string}> = [];
if (data.picture_json) {
  try {
    const raw = typeof data.picture_json === 'string' ? data.picture_json : JSON.stringify(data.picture_json);
    const parsed = JSON.parse(raw);
    pictures = Array.isArray(parsed) ? parsed : [parsed];
  } catch {}
}

// top_highlights
let highlights: string[] = [];
if (data.top_highlights) {
  const text = typeof data.top_highlights === 'string' ? data.top_highlights : JSON.stringify(data.top_highlights);
  highlights = text.split(/\n/).filter((s: string) => s.trim().match(/^[-*]\s/));
  if (highlights.length === 0 && text.trim()) highlights = [text];
}

