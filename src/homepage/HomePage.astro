---
import { getEmDashCollection, getEmDashEntry } from 'emdash'
import Layout from '../layouts/Base.astro'
import HeroBanner from './components/HeroBanner.astro'
import ProductGrid from './components/ProductGrid.astro'
import StatsSection from './components/StatsSection.astro'

const { entries: allEntries = [] } = await getEmDashCollection('products', { status: 'published' })
  .catch(() => ({ entries: [] }))

const { entry: heroEntry = null } = await getEmDashEntry('hero', 'home')
  .catch(() => ({ entry: null }))

const { entries: statEntries = [] } = await getEmDashCollection('stats', { status: 'published' })
  .catch(() => ({ entries: [] }))

/* 找到末级分类（depth 最深的 term） */
function findLeafTerm(terms: any[]): any {
  if (!terms || terms.length === 0) return null
  if (terms.length === 1) return terms[0]

  function getDepth(t: any): number {
    let d = 0
    let cur = t
    const seen = new Set<string>()
    while (cur) {
      const pid = Array.isArray(cur.parentId) ? cur.parentId[0] : cur.parentId
      if (!pid || seen.has(pid)) break
      seen.add(pid)
      const parent = terms.find(x => x.id === pid)
      if (!parent) break
      d++
      cur = parent
    }
    return d
  }

  let deepest = terms[0]
  let maxDepth = getDepth(terms[0])
  for (const t of terms) {
    const d = getDepth(t)
    if (d > maxDepth) { maxDepth = d; deepest = t }
  }
  return deepest
}

const products = (allEntries as any[])
  .filter((e: any) => e.data?.picture_json)
  .slice(0, 3)
  .map((e: any) => {
    let images: string[] = []
    let image = ''
    const raw = e.data?.picture_json
    let list: any[] = []
    if (typeof raw === 'string') {
      try { list = JSON.parse(raw) } catch { list = [] }
    } else if (Array.isArray(raw)) {
      list = raw
    } else if (raw && typeof raw === 'object') {
      list = [raw]
    }
    for (const item of list) {
      if (item && typeof item === 'object' && item.url) images.push(item.url)
      else if (typeof item === 'string') images.push(item)
    }
    image = images[0] ?? ''

    /* 从 terms.products1 中找末级分类（最深的那一级） */
    const terms = e.data?.terms?.products1 || []
    const leaf = findLeafTerm(terms)
    const categorySlug = leaf?.slug || ''

    return {
      id: e.id,
      title: e.data?.title ?? '',
      description: e.data?.description ?? '',
      image,
      images,
      link: categorySlug ? `/products?category=${categorySlug}` : `/products/${e.data.spu}`,
      tag: e.data?.danxuan ?? '',
      section: 'solutions',
      sort_order: 0,
      is_active: true,
    }
  })

const hero = heroEntry ? {
  badge_text: heroEntry.data?.badge_text ?? '',
  headline: heroEntry.data?.headline ?? '欢迎访问',
  subheadline: heroEntry.data?.subheadline ?? '',
  cta_text: heroEntry.data?.cta_text ?? '探索产品',
  cta_link: heroEntry.data?.cta_link ?? '/products',
  images: Array.isArray(heroEntry.data?.images) ? heroEntry.data.images : [],
} : {
  badge_text: '',
  headline: '欢迎访问 EmDash',
  subheadline: '',
  cta_text: '探索产品',
  cta_link: '/products',
  images: [],
}

const stats = statEntries.length > 0
  ? statEntries.map((s: any) => ({ number: String(s.data?.number ?? '0'), label: s.data?.label ?? '' }))
  : [
      { number: '50K+', label: '全球用户' },
      { number: '80+', label: '覆盖国家' },
      { number: '3K+', label: '在售 SKU' },
      { number: '99.2%', label: '好评率' },
    ]
---

<Layout title="EmDash — 智能热转印设备">
  <HeroBanner hero={hero} />
  <div style="background:#fff;">
    <ProductGrid products={products} title="一站式创意解决方案" subtitle="从设备到耗材，提供完整的热转印创作工具链" section="solutions" columns={3} />
  </div>
  <StatsSection stats={stats} />
  <div class="newsletter">
    <div class="newsletter-inner">
      <span class="newsletter-tag">STAY IN TOUCH</span>
      <h2 class="newsletter-title">获取最新资讯</h2>
      <p class="newsletter-desc">订阅邮件，获取新品发布与专属优惠</p>
      <form class="newsletter-form" onsubmit="return false">
        <input type="email" placeholder="输入您的邮箱地址" class="newsletter-input" />
        <button type="submit" class="newsletter-btn">订阅</button>
      </form>
    </div>
  </div>
</Layout>

<style>
  .newsletter{background:#111;padding:2.5rem 2rem;text-align:center}
  .newsletter-inner{max-width:480px;margin:0 auto}
  .newsletter-tag{display:inline-block;color:#22C55E;font-size:.75rem;font-weight:500;letter-spacing:2px;margin-bottom:.5rem}
  .newsletter-title{font-size:1.5rem;font-weight:700;color:#FAF5E6;margin:0 0 .25rem}
  .newsletter-desc{font-size:.8125rem;color:#D8CDB5;margin:0 0 1.25rem}
  .newsletter-form{display:flex;max-width:380px;margin:0 auto}
  .newsletter-input{flex:1;background:#FAF5E6;border:none;padding:.625rem 1rem;font-size:.8125rem;color:#333;border-radius:4px 0 0 4px;outline:none}
  .newsletter-input::placeholder{color:#BFAF8E}
  .newsletter-btn{background:#22C55E;color:#fff;border:none;padding:.625rem 1.25rem;font-size:.8125rem;font-weight:600;border-radius:0 4px 4px 0;cursor:pointer}
  .newsletter-btn:hover{background:#1DA34E}
</style>
