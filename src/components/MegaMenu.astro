---
const tree = [
  {
    slug: "company-news",
    name: "Company News",
    children: [
      { slug: "industry-trends", name: "Industry Trends", children: [{slug:"ai-tech",name:"AI Technology"},{slug:"market",name:"Market Analysis"}] },
      { slug: "company-events", name: "Company Events", children: [{slug:"annual",name:"Annual Meeting"},{slug:"team",name:"Team Building"}] }
    ]
  }
];
---

<nav style="background:#fff;border-bottom:1px solid #ddd;position:relative;z-index:9999">
  <div style="max-width:1200px;margin:0 auto;padding:0 24px;display:flex;align-items:center">
    <a href="/productss" style="display:flex;align-items:center;padding:10px 16px;font-size:14px;font-weight:600;color:#06c;text-decoration:none;border-bottom:2px solid #06c">All Products</a>
    
    {tree.map((top) => (
      <div style="position:relative" class="mm-item">
        <a href={"/productss?category="+top.slug} style="display:flex;align-items:center;gap:4px;padding:10px 16px;font-size:14px;font-weight:500;color:#525252;text-decoration:none;cursor:pointer">{top.name} &#9662;</a>
        
        <div style="position:absolute;top:100%;left:0;width:800px;background:#fff;border:2px solid #f00;border-radius:0 0 8px 8px;box-shadow:0 8px 32px rgba(0,0,0,.15);padding:16px" class="mm-drop">
          <div style="display:grid;grid-template-columns:200px 1fr">
            <div style="background:#f5f5f5;padding:16px;border-right:1px solid #eee">
              <div style="font-size:11px;text-transform:uppercase;color:#888;margin-bottom:12px;padding:0 8px">Categories</div>
              {top.children.map((child) => (
                <div style="position:relative;margin-bottom:4px" class="mm-row">
                  <span style="display:block;padding:8px 12px;font-size:14px;color:#333;cursor:pointer;border-right:3px solid transparent" class="mm-label">{child.name}</span>
                  
                  <div style="position:absolute;top:0;left:200px;width:600px;display:none;grid-template-columns:1fr 1fr;padding:16px;background:#fff;min-height:300px" class="mm-sub">
                    <div style="border-right:1px solid #eee;padding-right:16px">
                      <div style="font-size:11px;text-transform:uppercase;color:#888;margin-bottom:12px">{child.name}</div>
                      {child.children.map((g) => (
                        <a href={"/productss?category="+g.slug} style="display:block;padding:6px 8px;font-size:13px;color:#333;text-decoration:none">{g.name}</a>
                      ))}
                    </div>
                    <div style="padding-left:16px">
                      <div style="font-size:11px;text-transform:uppercase;color:#888;margin-bottom:12px">Featured</div>
                      <div style="display:flex;align-items:center;gap:12px;padding:8px">
                        <div style="width:48px;height:48px;background:#eee;border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:20px">📦</div>
                        <span>Sample Product</span>
                      </div>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    ))}
  </div>
</nav>

<style>
  .mm-drop { display: block !important; }
  .mm-row:hover .mm-sub { display: grid !important; }
  .mm-label:hover { background:#fff !important; border-color:#06c !important; font-weight:600 !important; }
</style>
