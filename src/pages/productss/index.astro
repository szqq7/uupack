---
import { getEmDashCollection } from "emdash";
import Base from "../../layouts/Base.astro";

let debug = "";
let productList = [];
let categoryCounts = new Map();

try {
  const { entries } = await getEmDashCollection("productss");
  productList = entries || [];
  
  // 调试：看第一个产品的结构
  if (productList[0]) {
    debug = JSON.stringify({
      keys: Object.keys(productList[0]),
      hasTerms: !!productList[0].terms,
      termsKeys: productList[0].terms ? Object.keys(productList[0].terms) : null,
      firstTerm: productList[0].terms?.product?.[0] || "NO TERMS"
    }, null, 2);
  } else {
    debug = "NO ENTRIES";
  }
  
  // 收集分类（如果有）
  productList.forEach(entry => {
    const terms = entry.terms?.product || [];
    terms.forEach(t => {
      categoryCounts.set(t.slug, (categoryCounts.get(t.slug) || 0) + 1);
    });
  });
  
} catch (e) {
  debug = `ERROR: ${e.message}`;
}
---

<Base title="Products">
  <div style="background:#ff0;padding:10px;font-size:11px;max-height:200px;overflow:auto;white-space:pre;">
    Debug: {debug}
    
    Total products: {productList.length}
    Counts: {JSON.stringify(Array.from(categoryCounts.entries()))}
  </div>

  <div class="products-page">
    <aside class="filter-sidebar">
      <div class="filter-section">
        <a href="/productss" class="filter-item all-products">All Products ({productList.length})</a>
      </div>
      
      <!-- 显示实际有的分类 -->
      {Array.from(categoryCounts.entries()).map(([slug, count]) => (
        <div class="filter-item">
          <input type="checkbox" onchange={`location.href='/productss?category=${slug}'`} />
          <span>{slug}</span>
          <span class="count">({count})</span>
        </div>
      ))}
    </aside>

    <main class="products-main">
      <div class="products-grid">
        {productList.slice(0, 8).map(product => (
          <a href={`/productss/${product.slug}`} class="product-card">
            <div class="product-image">
              <span>{product.data?.title?.substring(0, 20) || 'No title'}</span>
            </div>
          </a>
        ))}
      </div>
    </main>
  </div>
</Base>

<style>
  .products-page { max-width: 1400px; margin: 0 auto; padding: 2rem; display: grid; grid-template-columns: 260px 1fr; gap: 3rem; }
  .filter-sidebar { position: sticky; top: 2rem; height: fit-content; }
  .filter-section { padding: 0.75rem 0; border-bottom: 1px solid #e0e0e0; }
  .filter-item { display: flex; align-items: center; gap: 0.6rem; padding: 0.4rem 0.25rem; font-size: 0.88rem; color: #555; }
  .filter-item input { width: 16px; height: 16px; }
  .count { color: #999; font-size: 0.8rem; margin-left: auto; }
  .products-main { min-height: 400px; }
  .products-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem; }
  .product-card { border: 1px solid #f0f0f0; border-radius: 8px; padding: 1rem; text-decoration: none; color: #333; }
  .product-image { aspect-ratio: 1; background: #f8f9fa; display: flex; align-items: center; justify-content: center; }
</style>
