---
import { getEmDashEntry } from "emdash";
import Base from "../../layouts/Base.astro";

const { entry, cacheHint } = await getEmDashEntry("productss", Astro.params.slug);
if (!entry) return Astro.redirect("/404");

const data = entry.data || {};
const title = data.title || "Product";
const spu = data.spu || "";

let pictures = [];
if (data.picture_json) {
  try {
    const raw = typeof data.picture_json === "string" ? data.picture_json : JSON.stringify(data.picture_json);
    const parsed = JSON.parse(raw);
    pictures = Array.isArray(parsed) ? parsed : [parsed];
  } catch (e) {}
}

let highlightItems = [];
if (data.top_highlights) {
  const text = typeof data.top_highlights === "string" ? data.top_highlights : String(data.top_highlights);
  const lines = text.split(/\n/).filter((s) => s.trim().match(/^[-*]\s/));
  const items = lines.length > 0 ? lines : (text.trim() ? [text.trim()] : []);
  highlightItems = items.map((s) => s.trim().replace(/^[-*]\s*/, ""));
}

let details = [];
if (data.item_details) {
  try {
    let raw = typeof data.item_details === "string" ? data.item_details : JSON.stringify(data.item_details);
    raw = raw.replace(/,\s*,/g, ",").replace(/$$\s*,/g, "[").replace(/,\s*$$/g, "]");
    const parsed = JSON.parse(raw);
    if (Array.isArray(parsed)) {
      details = parsed.map((item) => ({ key: item.key || item.label || "Item", value: item.value || item.text || String(item) }));
    }
  } catch (e) {}
}

function boldText(s) { return s.replace(/\*\*(.+?)\*\*/g, "<strong>$1</strong>"); }
function getImgSrc(item) { return item?.url || item?.src || (typeof item === "string" ? item : ""); }
---

<Base title={title}>
  <div class="product-container">
    <div class="product-main">
      <!-- 左侧：图片 -->
      <div class="product-media">
        {pictures.length > 0 ? (
          <>
            <div class="main-image">
              <img id="mainImg" src={getImgSrc(pictures[0])} alt={title} />
            </div>
            {pictures.length > 1 && (
              <div class="thumbnail-list">
                {pictures.map((pic, i) => (
                  <img 
                    src={getImgSrc(pic)} 
                    class="thumb" 
                    data-index={i}
                    onclick={`document.getElementById('mainImg').src='${getImgSrc(pic)}'`}
                  />
                ))}
              </div>
            )}
          </>
        ) : (
          <div class="no-image">No Image</div>
        )}
      </div>

      <!-- 右侧：产品信息 -->
      <div class="product-info">
        <h1 class="product-title">{title}</h1>
        {spu && <div class="product-code">Code: {spu}</div>}

        {highlightItems.length > 0 && (
          <div class="info-section">
            <h3>Top Highlights</h3>
            <ul class="highlight-list">
              {highlightItems.map((item) => <li set:html={boldText(item)} />)}
            </ul>
          </div>
        )}

        {details.length > 0 && (
          <div class="info-section">
            <h3>Item Details</h3>
            <div class="specs-list">
              {details.map((d) => (
                <div class="spec-row">
                  <span class="spec-label">{d.key}</span>
                  <span class="spec-value">{d.value}</span>
                </div>
              ))}
            </div>
          </div>
        )}
      </div>
    </div>
  </div>
</Base>

<style>
  .product-container { max-width: 1200px; margin: 0 auto; padding: 2rem; }
  
  .product-main { display: grid; grid-template-columns: 500px 1fr; gap: 3rem; align-items: start; }
  
  /* 左侧图片 */
  .product-media { position: sticky; top: 2rem; }
  .main-image { width: 100%; aspect-ratio: 1; background: #f8f9fa; border-radius: 8px; overflow: hidden; display: flex; align-items: center; justify-content: center; }
  .main-image img { width: 100%; height: 100%; object-fit: contain; }
  .thumbnail-list { display: flex; gap: 0.5rem; margin-top: 1rem; overflow-x: auto; }
  .thumb { width: 80px; height: 80px; object-fit: cover; border-radius: 4px; border: 2px solid #e0e0e0; cursor: pointer; transition: border-color 0.2s; }
  .thumb:hover, .thumb.active { border-color: #333; }
  .no-image { width: 100%; aspect-ratio: 1; background: #f8f9fa; display: flex; align-items: center; justify-content: center; color: #999; border-radius: 8px; }

  /* 右侧信息 */
  .product-info { padding-top: 1rem; }
  .product-title { font-size: 1.75rem; font-weight: 600; margin-bottom: 0.5rem; line-height: 1.3; }
  .product-code { color: #666; font-size: 0.9rem; margin-bottom: 1.5rem; }
  
  .info-section { margin-bottom: 2rem; border-bottom: 1px solid #e0e0e0; padding-bottom: 1.5rem; }
  .info-section:last-child { border-bottom: none; }
  .info-section h3 { font-size: 1rem; font-weight: 600; margin-bottom: 1rem; color: #333; }
  
  .highlight-list { list-style: none; padding: 0; margin: 0; }
  .highlight-list li { padding: 0.5rem 0; padding-left: 1.2rem; position: relative; line-height: 1.6; color: #444; }
  .highlight-list li::before { content: "•"; position: absolute; left: 0; color: #666; font-weight: bold; }
  
  .specs-list { display: flex; flex-direction: column; gap: 0.75rem; }
  .spec-row { display: flex; justify-content: space-between; padding: 0.75rem 0; border-bottom: 1px solid #f0f0f0; }
  .spec-row:last-child { border-bottom: none; }
  .spec-label { color: #666; font-weight: 500; }
  .spec-value { color: #333; text-align: right; max-width: 60%; }

  @media (max-width: 900px) {
    .product-main { grid-template-columns: 1fr; }
    .product-media { position: static; }
  }
</style>
