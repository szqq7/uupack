---
interface Product { id: string; title: string; description: string; image: string; link: string; tag?: string }
export interface Props { product: Product }
const { product } = Astro.props
---
<a href={product.link} class="product-card">
  <div class="card-image">
    {product.image ? <img src={product.image} alt={product.title} loading="lazy" /> : <div class="image-placeholder">产品图</div>}
    {product.tag && <span class="card-tag" data-tag={product.tag}>{product.tag}</span>}
  </div>
  <div class="card-body">
    <h3 class="card-title">{product.title}</h3>
  </div>
</a>
<style>
  .product-card { display:block; border:1px solid #EBEBEB; border-radius:8px; overflow:hidden; text-decoration:none; color:inherit; transition:box-shadow 0.2s,transform 0.2s; cursor:pointer; background:#fff; }
  .product-card:hover { box-shadow:0 2px 12px rgba(0,0,0,0.06); transform:translateY(-2px); }
  .card-image { position:relative; aspect-ratio:16/10; overflow:hidden; background:#F0F0F0; }
  .card-image img { width:100%; height:100%; object-fit:cover; }
  .image-placeholder { width:100%; height:100%; display:flex; align-items:center; justify-content:center; color:#9B9B9B; font-size:.8125rem; background:#E8E8E8; }
  .card-tag { position:absolute; top:8px; left:8px; font-size:.6875rem; font-weight:500; padding:.125rem .5rem; border-radius:4px; color:#fff; }
  .card-tag[data-tag="热销"] { background:#22C55E; }
  .card-tag[data-tag="新品"] { background:#111; }
  .card-body { padding:1.25rem 1rem 1rem; }
  .card-title { font-size:1rem; font-weight:600; color:#111; margin:0; line-height:1.3; }
</style>
