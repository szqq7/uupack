---
---
// 测试标记：如果能看到这个，说明新代码已生效
const TEST_VERSION = "v3-three-column";
---
<nav class="mega-menu" aria-label="Product categories">
  <div style="background:red;color:white;padding:4px 16px;font-size:12px;">
    TEST: {TEST_VERSION}
  </div>
  ...

/**
 * MegaMenu.astro — 三级分类三栏式下拉菜单
 *
 * 布局: 左(20%) | 中(40%) | 右(40%)
 * 交互: 左列 hover 联动切换中列和右列
 */

import { getEmDashCollection } from "emdash";

const { entries } = await getEmDashCollection("productss");
const products = entries || [];

// 硬编码分类树（category_slugs 同步后自动切换为动态数据）
const fallbackTree = [
  {
    slug: "company-news",
    name: "Company News",
    children: [
      {
        slug: "industry-trends",
        name: "Industry Trends",
        children: [
          { slug: "ai-technology", name: "AI Technology" },
          { slug: "market-analysis", name: "Market Analysis" },
        ],
      },
      {
        slug: "company-events",
        name: "Company Events",
        children: [
          { slug: "annual-meeting", name: "Annual Meeting" },
          { slug: "company-corporates", name: "Company Corporates" },
          { slug: "company-milestones", name: "Company Milestones" },
          { slug: "team-building", name: "Team Building" },
          { slug: "test-news", name: "Test News" },
        ],
      },
    ],
  },
];

// 硬编码精选产品（category_slugs 同步后可替换为真实数据）
const fallbackFeatured: Record<string, { title: string; img: string }[]> = {
  "industry-trends": [
    { title: "AI Smart Sensor", img: "" },
    { title: "Market Report 2024", img: "" },
  ],
  "company-events": [
    { title: "Annual Gala Highlights", img: "" },
    { title: "Team Building Event", img: "" },
  ],
};

interface ChildNode { name: string; slug: string; children?: ChildNode[]; }
interface TopNode { name: string; slug: string; children: ChildNode[]; }

let tree: TopNode[] = [];
let featuredMap: Record<string, { title: string; img: string }[]> = {};

// 检查是否有动态数据
let hasData = false;
for (const p of products) {
  const raw = p.data?.category_slugs;
  if (!raw) continue;
  let slugs: string[];
  try { slugs = JSON.parse(typeof raw === "string" ? raw : JSON.stringify(raw)); }
  catch { continue; }
  if (Array.isArray(slugs) && slugs.length > 0) { hasData = true; break; }
}

if (hasData) {
  const slugIndex = new Map<string, ChildNode>();
  for (const p of products) {
    const raw = p.data?.category_slugs;
    if (!raw) continue;
    let slugs: string[];
    try { slugs = JSON.parse(typeof raw === "string" ? raw : JSON.stringify(raw)); }
    catch { continue; }
    if (!Array.isArray(slugs) || slugs.length === 0) continue;
    let parentSlug = "";
    for (const s of slugs) {
      const fullSlug = parentSlug ? `${parentSlug}/${s}` : s;
      if (!slugIndex.has(fullSlug)) {
        const node: ChildNode = {
          name: s.split("-").map((w: string) => w.charAt(0).toUpperCase() + w.slice(1)).join(" "),
          slug: s,
        };
        slugIndex.set(fullSlug, node);
        if (!parentSlug) {
          (tree as TopNode[]).push({ name: node.name, slug: node.slug, children: [] });
        } else {
          const parent = slugIndex.get(parentSlug);
          if (parent) {
            if (!parent.children) parent.children = [];
            parent.children.push(node);
          }
        }
      }
      parentSlug = fullSlug;
    }
  }
} else {
  tree = fallbackTree;
  featuredMap = fallbackFeatured;
}
---

<nav class="mega-menu" aria-label="Product categories">
  <div class="mega-menu-inner">
    <a href="/productss" class="mega-menu-all">All Products</a>

    {tree.map((top) => (
      <div class="mega-menu-item">
        <a
          href={`/productss?category=${top.slug}`}
          class="mega-menu-trigger"
          onmouseenter={`openMega(event, '${top.slug}')`}
        >
          {top.name}
          <span class="mega-arrow">▾</span>
        </a>

        <div class="mega-dropdown" id={`mega-${top.slug}`}>
          <div class="mega-panel">
            <!-- 左栏: 二级分类 -->
            <div class="mega-col mega-col-left">
              <div class="mega-col-title">Categories</div>
              {top.children.map((child, ci) => (
                <a
                  href={`/productss?category=${child.slug}`}
                  class:list={["mega-left-item", { "is-active": ci === 0 }]}
                  data-target={child.slug}
                  onmouseenter={`switchMega('${top.slug}', '${child.slug}')`}
                >
                  {child.name}
                </a>
              ))}
            </div>

            <!-- 中栏: 三级分类 -->
            <div class="mega-col mega-col-mid">
              {top.children.map((child) => (
                <div class="mega-mid-group" data-group={`${top.slug}-${child.slug}`}>
                  <div class="mega-col-title">{child.name}</div>
                  {child.children && child.children.map((grand) => (
                    <a href={`/productss?category=${grand.slug}`} class="mega-mid-link">
                      {grand.name}
                    </a>
                  ))}
                </div>
              ))}
            </div>

            <!-- 右栏: 精选产品 -->
            <div class="mega-col mega-col-right">
              {top.children.map((child) => {
                const featured = featuredMap[child.slug] || [];
                return (
                  <div class="mega-right-group" data-group={`${top.slug}-${child.slug}`}>
                    <div class="mega-col-title">Featured</div>
                    {featured.length > 0 ? featured.map((item) => (
                      <div class="mega-featured-item">
                        <div class="mega-featured-img">
                          {item.img ? (
                            <img src={item.img} alt={item.title} loading="lazy" />
                          ) : (
                            <div class="mega-featured-placeholder">{item.title.charAt(0)}</div>
                          )}
                        </div>
                        <span class="mega-featured-title">{item.title}</span>
                      </div>
                    )) : (
                      <p class="mega-featured-empty">Products coming soon</p>
                    )}
                  </div>
                );
              })}
            </div>
          </div>
        </div>
      </div>
    ))}
  </div>
</nav>

<script>
  function openMega(e, slug) {
    document.querySelectorAll('.mega-dropdown.open').forEach(el => {
      if (el.id !== 'mega-' + slug) el.classList.remove('open');
    });
    const panel = document.getElementById('mega-' + slug);
    if (panel) panel.classList.add('open');
    const first = document.querySelector('#mega-' + slug + ' .mega-left-item');
    if (first) switchMega(slug, first.dataset.target || '');
  }

  function switchMega(topSlug, childSlug) {
    const panel = document.getElementById('mega-' + topSlug);
    if (!panel) return;
    panel.querySelectorAll('.mega-left-item').forEach(el => el.classList.remove('is-active'));
    const leftItem = panel.querySelector('.mega-left-item[data-target="' + childSlug + '"]');
    if (leftItem) leftItem.classList.add('is-active');
    panel.querySelectorAll('.mega-mid-group, .mega-right-group').forEach(el => el.classList.remove('is-visible'));
    panel.querySelectorAll('[data-group="' + topSlug + '-' + childSlug + '"]').forEach(el => el.classList.add('is-visible'));
  }

  document.addEventListener('mouseover', function(e) {
    if (!e.target.closest('.mega-menu-item')) {
      document.querySelectorAll('.mega-dropdown.open').forEach(el => el.classList.remove('open'));
    }
  });
</script>

<style>
  .mega-menu { background: var(--color-bg); border-bottom: 1px solid var(--color-border-subtle); position: relative; z-index: 99; }
  .mega-menu-inner { max-width: var(--wide-width); margin: 0 auto; padding: 0 var(--spacing-6); display: flex; align-items: center; gap: 0; overflow-x: auto; scrollbar-width: none; -ms-overflow-style: none; }
  .mega-menu-inner::-webkit-scrollbar { display: none; }
  .mega-menu-all { display: inline-flex; align-items: center; gap: var(--spacing-2); padding: 0.6rem 1rem; font-size: var(--font-size-sm); font-weight: 600; color: var(--color-accent); text-decoration: none; white-space: nowrap; border-bottom: 2px solid var(--color-accent); transition: color var(--transition-fast); flex-shrink: 0; }
  .mega-menu-all:hover { color: var(--color-text); }
  .mega-menu-item { position: relative; flex-shrink: 0; }
  .mega-menu-trigger { display: inline-flex; align-items: center; gap: 0.3rem; padding: 0.6rem 1rem; font-size: var(--font-size-sm); font-weight: 500; color: var(--color-text-secondary); text-decoration: none; white-space: nowrap; border-bottom: 2px solid transparent; transition: all var(--transition-fast); cursor: pointer; }
  .mega-menu-trigger:hover { color: var(--color-text); border-bottom-color: var(--color-accent); }
  .mega-arrow { font-size: 0.65rem; color: var(--color-text-tertiary); transition: transform var(--transition-fast); }
  .mega-menu-item:hover .mega-arrow { transform: rotate(180deg); }
  .mega-dropdown { position: absolute; top: 100%; left: 0; width: 820px; max-width: 90vw; background: var(--color-bg); border: 1px solid var(--color-border-subtle); border-radius: 0 0 var(--radius-lg) var(--radius-lg); box-shadow: 0 12px 40px rgba(0,0,0,0.10); opacity: 0; visibility: hidden; transform: translateY(-6px); transition: all 0.2s ease; z-index: 200; }
  .mega-dropdown.open { opacity: 1; visibility: visible; transform: translateY(0); }
  .mega-panel { display: grid; grid-template-columns: 1fr 2fr 2fr; min-height: 280px; }
  .mega-col { padding: 1rem 0; }
  .mega-col-title { padding: 0.3rem 1rem; font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: var(--color-muted); margin-bottom: 0.25rem; }
  .mega-col-left { background: var(--color-surface); border-right: 1px solid var(--color-border-subtle); }
  .mega-left-item { display: block; padding: 0.45rem 1rem; font-size: var(--font-size-sm); font-weight: 500; color: var(--color-text-secondary); text-decoration: none; transition: all var(--transition-fast); cursor: pointer; border-right: 2px solid transparent; }
  .mega-left-item:hover, .mega-left-item.is-active { color: var(--color-text); background: var(--color-bg); border-right-color: var(--color-accent); font-weight: 600; }
  .mega-col-mid { border-right: 1px solid var(--color-border-subtle); }
  .mega-mid-group { display: none; }
  .mega-mid-group.is-visible { display: block; }
  .mega-mid-link { display: block; padding: 0.35rem 1rem; font-size: var(--font-size-sm); color: var(--color-text); text-decoration: none; border-radius: 4px; margin: 0 0.5rem; transition: background var(--transition-fast); }
  .mega-mid-link:hover { background: var(--color-surface); color: var(--color-accent); }
  .mega-right-group { display: none; }
  .mega-right-group.is-visible { display: block; }
  .mega-featured-item { display: flex; align-items: center; gap: 0.75rem; padding: 0.4rem 1rem; text-decoration: none; color: inherit; border-radius: 4px; margin: 0 0.5rem; transition: background var(--transition-fast); }
  .mega-featured-item:hover { background: var(--color-surface); }
  .mega-featured-img { width: 48px; height: 48px; border-radius: 6px; overflow: hidden; flex-shrink: 0; background: var(--color-surface); }
  .mega-featured-img img { width: 100%; height: 100%; object-fit: cover; }
  .mega-featured-placeholder { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; font-size: 1.2rem; font-weight: 700; color: var(--color-muted); background: var(--color-border-subtle); }
  .mega-featured-title { font-size: var(--font-size-sm); font-weight: 500; color: var(--color-text); }
  .mega-featured-empty { padding: 0.4rem 1rem; font-size: var(--font-size-sm); color: var(--color-muted); }
  @media (max-width: 900px) { .mega-dropdown { width: 600px; } .mega-panel { grid-template-columns: 1fr 1fr; } .mega-col-right { display: none; } }
  @media (max-width: 768px) { .mega-menu { display: none; } }
</style>
