---
import { getEmDashCollection } from "emdash";

const { entries } = await getEmDashCollection("productss");
const products = entries || [];

// 硬编码完整分类树 — 平铺一级，hover 下拉二三级
const fallbackTree = [
  {
    slug: "company-news",
    name: "Company News",
    children: [
      {
        slug: "industry-trends",
        name: "Industry Trends",
        children: [
          { slug: "ai-technology", name: "AI Technology", children: [] },
          { slug: "market-analysis", name: "Market Analysis", children: [] },
        ],
      },
      {
        slug: "company-events",
        name: "Company Events",
        children: [
          { slug: "annual-meeting", name: "Annual Meeting", children: [] },
          { slug: "company-corporates", name: "Company Corporates", children: [] },
          { slug: "company-milestones", name: "Company Milestones", children: [] },
          { slug: "team-building", name: "Team Building", children: [] },
          { slug: "test-news", name: "Test News", children: [] },
        ],
      },
    ],
  },
];

interface CatNode {
  name: string;
  slug: string;
  children: CatNode[];
}

let tree: CatNode[] = [];

let hasData = false;
for (const p of products) {
  const raw = p.data?.category_slugs;
  if (!raw) continue;
  let slugs: string[];
  try { slugs = JSON.parse(typeof raw === "string" ? raw : JSON.stringify(raw)); }
  catch { continue; }
  if (!Array.isArray(slugs) || slugs.length === 0) continue;
  hasData = true;
  break;
}

if (hasData) {
  const slugIndex = new Map<string, CatNode>();
  for (const p of products) {
    const raw = p.data?.category_slugs;
    if (!raw) continue;
    let slugs: string[];
    try { slugs = JSON.parse(typeof raw === "string" ? raw : JSON.stringify(raw)); }
    catch { continue; }
    if (!Array.isArray(slugs) || slugs.length === 0) continue;
    let parentSlug = "";
    for (const s of slugs) {
      const fullSlug = parentSlug ? `${parentSlug}/${s}` : s;
      if (!slugIndex.has(fullSlug)) {
        const node: CatNode = {
          name: s.split("-").map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(" "),
          slug: s, children: [],
        };
        slugIndex.set(fullSlug, node);
        if (!parentSlug) tree.push(node);
        else slugIndex.get(parentSlug)?.children.push(node);
      }
      parentSlug = fullSlug;
    }
  }
} else {
  tree = fallbackTree;
}
---

<nav class="mega-menu" aria-label="Product categories">
  <div class="mega-menu-inner">
    <a href="/productss" class="mega-menu-all">All Products</a>
    {tree.map((top) => (
      <div class="mega-menu-item">
        <a href={`/productss?category=${top.slug}`} class="mega-menu-trigger">
          {top.name}
          {top.children.length > 0 && <span class="mega-arrow">▾</span>}
        </a>
        {top.children.length > 0 && (
          <div class="mega-menu-dropdown">
            <div class="mega-menu-panel">
              <a href={`/productss?category=${top.slug}`} class="mega-drop-head">All {top.name}</a>
              {top.children.map((child) => (
                <div class="mega-subgroup">
                  <a href={`/productss?category=${child.slug}`} class="mega-sub-link">{child.name}</a>
                  {child.children.length > 0 && (
                    <div class="mega-grandchildren">
                      {child.children.map((grand) => (
                        <a href={`/productss?category=${grand.slug}`} class="mega-grand-link">{grand.name}</a>
                      ))}
                    </div>
                  )}
                </div>
              ))}
            </div>
          </div>
        )}
      </div>
    ))}
  </div>
</nav>

<style>
  .mega-menu { background: var(--color-bg); border-bottom: 1px solid var(--color-border-subtle); position: relative; z-index: 99; }
  .mega-menu-inner { max-width: var(--wide-width); margin: 0 auto; padding: 0 var(--spacing-6); display: flex; align-items: center; gap: 0; overflow-x: auto; scrollbar-width: none; -ms-overflow-style: none; }
  .mega-menu-inner::-webkit-scrollbar { display: none; }
  .mega-menu-all { display: inline-flex; align-items: center; gap: var(--spacing-2); padding: 0.6rem 1rem; font-size: var(--font-size-sm); font-weight: 600; color: var(--color-accent); text-decoration: none; white-space: nowrap; border-bottom: 2px solid var(--color-accent); transition: color var(--transition-fast); flex-shrink: 0; }
  .mega-menu-all:hover { color: var(--color-text); }
  .mega-menu-item { position: relative; flex-shrink: 0; }
  .mega-menu-trigger { display: inline-flex; align-items: center; gap: 0.3rem; padding: 0.6rem 1rem; font-size: var(--font-size-sm); font-weight: 500; color: var(--color-text-secondary); text-decoration: none; white-space: nowrap; border-bottom: 2px solid transparent; transition: all var(--transition-fast); cursor: pointer; }
  .mega-menu-trigger:hover { color: var(--color-text); border-bottom-color: var(--color-accent); }
  .mega-arrow { font-size: 0.65rem; color: var(--color-text-tertiary); transition: transform var(--transition-fast); }
  .mega-menu-item:hover .mega-arrow { transform: rotate(180deg); }
  .mega-menu-dropdown { position: absolute; top: 100%; left: 0; min-width: 240px; max-width: 320px; background: var(--color-bg); border: 1px solid var(--color-border-subtle); border-radius: 0 0 var(--radius) var(--radius); box-shadow: 0 8px 24px rgba(0,0,0,0.08); opacity: 0; visibility: hidden; transform: translateY(-4px); transition: all 0.18s ease; z-index: 200; }
  .mega-menu-item:hover .mega-menu-dropdown,
  .mega-menu-item:focus-within .mega-menu-dropdown { opacity: 1; visibility: visible; transform: translateY(0); }
  .mega-menu-panel { padding: 0.5rem 0; }
  .mega-drop-head { display: block; padding: 0.5rem 0.85rem; font-size: var(--font-size-sm); font-weight: 700; color: var(--color-accent); text-decoration: none; border-bottom: 1px solid var(--color-border-subtle); margin: 0 0.5rem 0.25rem; }
  .mega-drop-head:hover { color: var(--color-text); }
  .mega-subgroup { padding: 0; }
  .mega-sub-link { display: block; padding: 0.4rem 0.85rem; font-size: var(--font-size-sm); font-weight: 500; color: var(--color-text); text-decoration: none; transition: background var(--transition-fast); }
  .mega-sub-link:hover { background: var(--color-surface); }
  .mega-grandchildren { padding: 0 0 0.25rem 0.5rem; }
  .mega-grand-link { display: block; padding: 0.3rem 0.85rem; font-size: var(--font-size-xs); color: var(--color-text-tertiary); text-decoration: none; transition: all var(--transition-fast); }
  .mega-grand-link:hover { color: var(--color-text); background: var(--color-surface); }
  @media (max-width: 768px) { .mega-menu { display: none; } }
</style>
