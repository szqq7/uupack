---
const tree = [
  {
    slug: "company-news",
    name: "Company News",
    children: [
      { slug: "industry-trends", name: "Industry Trends", children: [{slug:"ai-technology",name:"AI Technology"},{slug:"market-analysis",name:"Market Analysis"}] },
      { slug: "company-events", name: "Company Events", children: [{slug:"annual-meeting",name:"Annual Meeting"},{slug:"team-building",name:"Team Building"}] }
    ]
  }
];
---

<nav class="mega-menu">
  <div class="mega-inner">
    <a href="/productss" class="mega-all">All Products</a>
    
    {tree.map((top) => (
      <div class="mega-item">
        <a href={"/productss?category="+top.slug} class="mega-trigger">{top.name} <span class="arrow">&#9662;</span></a>
        
        <div class="mega-drop">
          <div class="mega-grid">
            <div class="col-left">
              <div class="col-title">Categories</div>
              {top.children.map((child) => (
                <div class="left-row">
                  <a href={"/productss?category="+child.slug} class="left-name">{child.name}</a>
                  
                  <div class="sub-panel">
                    <div class="col-mid">
                      <div class="col-title">{child.name}</div>
                      {child.children.map((g) => (
                        <a href={"/productss?category="+g.slug} class="mid-link">{g.name}</a>
                      ))}
                    </div>
                    <div class="col-right">
                      <div class="col-title">Featured</div>
                      <div class="feat-item">
                        <div class="feat-img">📦</div>
                        <span>Sample Product</span>
                      </div>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    ))}
  </div>
</nav>

<style>
.mega-menu{background:#fff;border-bottom:1px solid #ddd;position:relative;z-index:9999}
.mega-inner{max-width:1200px;margin:0 auto;padding:0 24px;display:flex;align-items:center}
.mega-all{display:flex;align-items:center;padding:10px 16px;font-size:14px;font-weight:600;color:#06c;text-decoration:none;border-bottom:2px solid #06c}
.mega-item{position:relative}
.mega-trigger{display:flex;align-items:center;gap:4px;padding:10px 16px;font-size:14px;font-weight:500;color:#525252;text-decoration:none;border-bottom:2px solid transparent}
.mega-trigger:hover{color:#000;border-color:#06c}
.arrow{font-size:10px;transition:transform .2s}
.mega-item:hover .arrow{transform:rotate(180deg)}
.mega-drop{position:absolute;top:100%;left:0;width:800px;background:#fff;border:1px solid #ddd;border-radius:0 0 8px 8px;box-shadow:0 8px 32px rgba(0,0,0,.15);padding:16px;display:none}
.mega-item:hover .mega-drop{display:block}
.mega-grid{display:grid;grid-template-columns:200px 1fr}
.col-left{background:#f5f5f5;padding:16px;border-right:1px solid #eee}
.col-title{font-size:11px;text-transform:uppercase;color:#888;margin-bottom:12px;padding:0 8px}
.left-row{position:relative;margin-bottom:4px}
.left-name{display:block;padding:8px 12px;font-size:14px;color:#333;text-decoration:none;border-right:3px solid transparent}
.left-name:hover{background:#fff;border-color:#06c;font-weight:600}
.sub-panel{position:absolute;top:0;left:200px;width:600px;display:none;grid-template-columns:1fr 1fr;padding:16px;background:#fff;min-height:280px;z-index:100}
.left-row:hover .sub-panel{display:grid}
.col-mid{border-right:1px solid #eee;padding-right:16px}
.mid-link{display:block;padding:8px 12px;font-size:13px;color:#333;text-decoration:none;border-radius:4px;margin:2px 0}
.mid-link:hover{background:#f0f0f0;color:#06c}
.col-right{padding-left:16px}
.feat-item{display:flex;align-items:center;gap:12px;padding:12px;text-decoration:none;color:#333;border-radius:4px}
.feat-item:hover{background:#f0f0f0}
.feat-img{width:48px;height:48px;background:#eee;border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:20px}
@media(max-width:900px){.mega-drop{width:600px}.sub-panel{width:400px}}
@media(max-width:768px){.mega-menu{display:none}}
</style>
