---
import { getEmDashCollection } from "emdash";
import Base from "../../layouts/Base.astro";

// 获取所有产品
const { entries } = await getEmDashCollection("productss");

// 提取所有分类（从产品数据中的 category/terms 字段）
const categories = new Map();
entries?.forEach(entry => {
  const terms = entry.terms?.product || [];
  terms.forEach(term => {
    if (!categories.has(term.slug)) {
      categories.set(term.slug, { ...term, count: 0 });
    }
    categories.get(term.slug).count++;
  });
});

// 获取 URL 参数
const url = new URL(Astro.request.url);
const selectedCategories = url.searchParams.getAll("category");

// 筛选产品
const filteredProducts = selectedCategories.length > 0
  ? entries?.filter(e => {
      const productTerms = e.terms?.product?.map(t => t.slug) || [];
      return selectedCategories.some(cat => productTerms.includes(cat));
    })
  : entries;

function getFirstImage(entry) {
  try {
    const raw = typeof entry.data?.picture_json === 'string' 
      ? entry.data.picture_json 
      : JSON.stringify(entry.data?.picture_json);
    const parsed = JSON.parse(raw);
    const pics = Array.isArray(parsed) ? parsed : [parsed];
    return pics[0]?.url || pics[0]?.src || pics[0] || '';
  } catch {
    return '';
  }
}
---

<Base title="Products">
  <div class="products-page">
    <!-- 左侧筛选栏 -->
    <aside class="filter-sidebar">
      <div class="filter-section">
        <h3 class="filter-title">All Products</h3>
        <label class="filter-item">
          <input type="checkbox" checked={selectedCategories.length === 0} onchange="location.href='/productss'" />
          <span>All Products</span>
        </label>
      </div>

      <!-- 动态生成分类（按字母排序） -->
      {Array.from(categories.values()).sort((a, b) => a.name.localeCompare(b.name)).map(cat => (
        <div class="filter-section">
          <label class="filter-item">
            <input 
              type="checkbox" 
              value={cat.slug}
              checked={selectedCategories.includes(cat.slug)}
              onchange={`toggleCategory('${cat.slug}')`}
            />
            <span>{cat.name}</span>
            <span class="count">({cat.count})</span>
          </label>
        </div>
      ))}
    </aside>

    <!-- 右侧产品列表 -->
    <main class="products-grid">
      <h1 class="page-title">Products {selectedCategories.length > 0 && `(${filteredProducts?.length})`}</h1>
      
      <div class="grid">
        {filteredProducts?.map(product => (
          <a href={`/productss/${product.slug}`} class="product-card">
            <div class="product-image">
              {getFirstImage(product) ? (
                <img src={getFirstImage(product)} alt={product.data?.title} loading="lazy" />
              ) : (
                <div class="no-image">No Image</div>
              )}
            </div>
            <h3 class="product-title">{product.data?.title}</h3>
          </a>
        ))}
      </div>

      {filteredProducts?.length === 0 && (
        <div class="empty-state">No products found</div>
      )}
    </main>
  </div>

  <script is:inline>
    function toggleCategory(slug) {
      const url = new URL(location.href);
      const current = url.searchParams.getAll('category');
      
      if (current.includes(slug)) {
        url.searchParams.delete('category');
        current.filter(c => c !== slug).forEach(c => url.searchParams.append('category', c));
      } else {
        url.searchParams.append('category', slug);
      }
      
      location.href = url.toString();
    }
  </script>
</Base>

<style>
  .products-page {
    max-width: 1400px;
    margin: 0 auto;
    padding: 2rem;
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: 3rem;
  }

  /* 左侧筛选 */
  .filter-sidebar {
    position: sticky;
    top: 2rem;
    height: fit-content;
  }
  .filter-section {
    border-bottom: 1px solid #e0e0e0;
    padding: 1rem 0;
  }
  .filter-title {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.75rem;
    color: #333;
  }
  .filter-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 0;
    cursor: pointer;
    font-size: 0.9rem;
    color: #555;
  }
  .filter-item:hover {
    color: #000;
  }
  .filter-item input[type="checkbox"] {
    width: 16px;
    height: 16px;
    cursor: pointer;
  }
  .count {
    color: #999;
    font-size: 0.85rem;
  }

  /* 右侧网格 */
  .page-title {
    font-size: 1.5rem;
    font-weight: 600;
    margin-bottom: 1.5rem;
    color: #333;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }
  .product-card {
    text-decoration: none;
    color: inherit;
    transition: transform 0.2s;
  }
  .product-card:hover {
    transform: translateY(-4px);
  }
  .product-image {
    aspect-ratio: 1;
    background: #f8f9fa;
    border-radius: 8px;
    overflow: hidden;
    margin-bottom: 0.75rem;
  }
  .product-image img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 1rem;
  }
  .no-image {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #999;
    font-size: 0.9rem;
  }
  .product-title {
    font-size: 0.95rem;
    font-weight: 500;
    line-height: 1.4;
    color: #333;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .empty-state {
    grid-column: 1 / -1;
    text-align: center;
    padding: 4rem;
    color: #999;
  }

  @media (max-width: 1024px) {
    .grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 768px) {
    .products-page { grid-template-columns: 1fr; }
    .filter-sidebar { position: static; }
    .grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>
