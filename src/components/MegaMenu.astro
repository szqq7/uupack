---
import { getEmDashCollection } from "emdash";

const { entries } = await getEmDashCollection("productss");
const products = entries || [];

function slugToName(slug: string): string {
  return slug
    .split("-")
    .map((w) => w.charAt(0).toUpperCase() + w.slice(1))
    .join(" ");
}

interface CatNode {
  name: string;
  slug: string;
  children: CatNode[];
  count: number;
}

const tree: CatNode[] = [];
const slugIndex = new Map<string, CatNode>();

for (const p of products) {
  const raw = p.data?.category_slugs;
  if (!raw) continue;
  let slugs: string[];
  try {
    slugs = JSON.parse(typeof raw === "string" ? raw : JSON.stringify(raw));
  } catch { continue; }
  if (!Array.isArray(slugs) || slugs.length === 0) continue;

  let parentSlug = "";
  for (const s of slugs) {
    const fullSlug = parentSlug ? `${parentSlug}/${s}` : s;
    if (!slugIndex.has(fullSlug)) {
      const node: CatNode = {
        name: slugToName(s), slug: s, children: [], count: 0,
      };
      slugIndex.set(fullSlug, node);
      if (!parentSlug) tree.push(node);
      else slugIndex.get(parentSlug)?.children.push(node);
    }
    slugIndex.get(fullSlug)!.count++;
    parentSlug = fullSlug;
  }
}

function sortTree(nodes: CatNode[]) {
  nodes.sort((a, b) => b.count - a.count);
  nodes.forEach((n) => sortTree(n.children));
}
sortTree(tree);
---

<nav class="mega-menu" aria-label="Product categories">
  <div class="mega-menu-inner">
    <a href="/productss" class="mega-menu-all">All Products</a>

    {tree.map((top) => (
      <div class="mega-menu-item">
        <a href={`/productss?category=${top.slug}`} class="mega-menu-trigger">
          {top.name}
          {top.children.length > 0 && <span class="mega-arrow">▾</span>}
        </a>

        {top.children.length > 0 && (
          <div class="mega-menu-dropdown">
            <div class="mega-menu-panel">
              <div class="mega-menu-col">
                <a href={`/productss?category=${top.slug}`} class="mega-cat-head">
                  All {top.name}
                </a>
                {top.children.map((child) => (
                  <div class="mega-subgroup">
                    <a href={`/productss?category=${child.slug}`} class="mega-sub-link">
                      {child.name}
                      <span class="mega-count">({child.count})</span>
                    </a>
                    {child.children.length > 0 && (
                      <div class="mega-grandchildren">
                        {child.children.map((grand) => (
                          <a href={`/productss?category=${grand.slug}`} class="mega-grand-link">
                            {grand.name}
                          </a>
                        ))}
                      </div>
                    )}
                  </div>
                ))}
              </div>
            </div>
          </div>
        )}
      </div>
    ))}
  </div>
</nav>

<style>
  .mega-menu { background: var(--color-bg); border-bottom: 1px solid var(--color-border-subtle); position: relative; z-index: 99; }
  .mega-menu-inner { max-width: var(--wide-width); margin: 0 auto; padding: 0 var(--spacing-6); display: flex; align-items: center; gap: 0; overflow-x: auto; scrollbar-width: none; }
  .mega-menu-inner::-webkit-scrollbar { display: none; }
  .mega-menu-all { display: inline-flex; align-items: center; gap: var(--spacing-2); padding: 0.6rem 1rem; font-size: var(--font-size-sm); font-weight: 600; color: var(--color-accent); text-decoration: none; white-space: nowrap; border-bottom: 2px solid var(--color-accent); transition: color var(--transition-fast); flex-shrink: 0; }
  .mega-menu-all:hover { color: var(--color-text); }
  .mega-menu-item { position: relative; flex-shrink: 0; }
  .mega-menu-trigger { display: inline-flex; align-items: center; gap: 0.3rem; padding: 0.6rem 1rem; font-size: var(--font-size-sm); font-weight: 500; color: var(--color-text-secondary); text-decoration: none; white-space: nowrap; border-bottom: 2px solid transparent; transition: all var(--transition-fast); }
  .mega-menu-trigger:hover { color: var(--color-text); border-bottom-color: var(--color-accent); }
  .mega-arrow { font-size: 0.65rem; color: var(--color-text-tertiary); transition: transform var(--transition-fast); }
  .mega-menu-item:hover .mega-arrow { transform: rotate(180deg); }
  .mega-menu-dropdown { position: absolute; top: 100%; left: 0; min-width: 280px; max-width: 400px; background: var(--color-bg); border: 1px solid var(--color-border-subtle); border-radius: 0 0 var(--radius) var(--radius); box-shadow: 0 8px 24px rgba(0,0,0,0.08); opacity: 0; visibility: hidden; transform: translateY(-4px); transition: all 0.18s ease; z-index: 200; }
  .mega-menu-item:hover .mega-menu-dropdown,
  .mega-menu-item:focus-within .mega-menu-dropdown { opacity: 1; visibility: visible; transform: translateY(0); }
  .mega-menu-panel { padding: 0.75rem; }
  .mega-menu-col { display: flex; flex-direction: column; gap: 0; }
  .mega-cat-head { display: block; padding: 0.5rem 0.75rem; font-size: var(--font-size-sm); font-weight: 700; color: var(--color-accent); text-decoration: none; border-bottom: 1px solid var(--color-border-subtle); margin-bottom: 0.25rem; }
  .mega-cat-head:hover { color: var(--color-text); }
  .mega-subgroup { padding: 0; }
  .mega-sub-link { display: flex; align-items: center; justify-content: space-between; padding: 0.45rem 0.75rem; font-size: var(--font-size-sm); font-weight: 500; color: var(--color-text); text-decoration: none; border-radius: var(--radius-sm); }
  .mega-sub-link:hover { background: var(--color-surface); }
  .mega-count { font-size: var(--font-size-xs); color: var(--color-text-tertiary); }
  .mega-grandchildren { padding: 0 0 0.25rem 0.75rem; }
  .mega-grand-link { display: block; padding: 0.3rem 0.75rem; font-size: var(--font-size-xs); color: var(--color-text-tertiary); text-decoration: none; border-radius: var(--radius-sm); }
  .mega-grand-link:hover { color: var(--color-text); background: var(--color-surface); }
  @media (max-width: 768px) { .mega-menu { display: none; } }
</style>
