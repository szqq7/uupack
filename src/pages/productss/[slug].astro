---
import { getEmDashCollection, getEmDashEntry } from "emdash";
import Base from "../../layouts/Base.astro";

// ========= 1. 获取所有产品 =========
const { entries } = await getEmDashCollection("productss");

// ========= 2. 逐个查详情拿 terms（9条数据，秒级完成）=========
const productList = [];
for (const e of (entries || [])) {
  try {
    const full = await getEmDashEntry("productss", e.slug);
    if (full.entry) productList.push(full.entry);
    else productList.push(e);
  } catch { productList.push(e); }
}

// ========= 3. 从 terms 统计每个分类的产品数量 =========
const categoryCounts = new Map();
productList.forEach(entry => {
  const terms = entry?.terms?.product || [];
  terms.forEach(term => {
    const slug = term.slug;
    categoryCounts.set(slug, (categoryCounts.get(slug) || 0) + 1);
  });
});

// ========= 4. 分类树 =========
const categoryTree = [
  {
    slug: "company-news",
    name: "Company News",
    children: [
      { slug: "company-industry", name: "Industry Trends", children: [
        { slug: "ai-technology", name: "AI Technology" },
        { slug: "market-analysis", name: "Market Analysis" }
      ]},
      { slug: "company-events", name: "Company Events", children: [
        { slug: "annual-meeting", name: "Annual Meeting" },
        { slug: "company-corporates", name: "Company Corporates" },
        { slug: "company-milestones", name: "Company Milestones" },
        { slug: "team-building", name: "Team Building" },
        { slug: "test-news", name: "Test News" }
      ]}
    ]
  }
];

// ========= 5. 扁平收集所有有子类的节点 =========
function collectSections(tree) {
  const result = [];
  tree.forEach(node => {
    if (node.children && node.children.length > 0) {
      result.push({
        slug: node.slug,
        name: node.name,
        children: node.children.map(c => c.slug)
      });
      result.push(...collectSections(node.children));
    }
  });
  return result;
}
const sections = collectSections(categoryTree);

// 构建 slug → name 映射
const slugNameMap = new Map();
(function walk(nodes) {
  nodes.forEach(n => {
    slugNameMap.set(n.slug, n.name);
    if (n.children) walk(n.children);
  });
})(categoryTree);

// ========= 6. URL 筛选逻辑 =========
const url = new URL(Astro.request.url);
const activeCategories = url.searchParams.getAll("category");

const filteredProducts = activeCategories.length > 0
  ? productList.filter(entry => {
      const slugs = (entry?.terms?.product || []).map(t => t.slug);
      return activeCategories.some(c => slugs.includes(c));
    })
  : productList;

// ========= 7. 图片提取 =========
function getFirstImage(entry) {
  try {
    if (!entry?.data?.picture_json) return '';
    const raw = typeof entry.data.picture_json === 'string'
      ? entry.data.picture_json
      : JSON.stringify(entry.data.picture_json);
    if (!raw || raw === 'null' || raw === '{}') return '';
    const pics = JSON.parse(raw);
    const arr = Array.isArray(pics) ? pics : [pics];
    return arr[0]?.url || arr[0]?.src || arr[0] || '';
  } catch { return ''; }
}
---

<Base title="Products">
  <div class="products-page">
    <!-- ===== 左侧筛选栏 ===== -->
    <aside class="filter-sidebar">
      
      <!-- 顶部固定入口 -->
      <div class="top-entries">
        <a href="/productss" class={`top-item ${activeCategories.length === 0 ? 'active' : ''}`}>
          <span>All Products</span>
          <span class="count">({productList.length})</span>
        </a>
        <label class="top-item">
          <input type="checkbox" disabled />
          <span>New Arrivals</span>
          <span class="count">(0)</span>
        </label>
        <label class="top-item">
          <input type="checkbox" disabled />
          <span>Top Picks</span>
          <span class="count">(0)</span>
        </label>
        <label class="top-item">
          <input type="checkbox" disabled />
          <span>Deals &amp; Discounts</span>
          <span class="count">(0)</span>
        </label>
      </div>

      <!-- 动态分类组 -->
      {sections.map(section => (
        <div class="category-block">
          <span class="cat-title">{section.name}</span>
          <div class="cat-items">
            {section.children.map(childSlug => {
              const childName = slugNameMap.get(childSlug) || childSlug;
              const count = categoryCounts.get(childSlug) || 0;
              const checked = activeCategories.includes(childSlug);
              return (
                <label class={`cat-item ${checked ? 'active' : ''}`}>
                  <input type="checkbox" checked={checked} onchange={`toggle('${childSlug}')`} />
                  <span>{childName}</span>
                  <span class="count">({count})</span>
                </label>
              );
            })}
          </div>
        </div>
      ))}
    </aside>

    <!-- ===== 右侧产品网格 ===== -->
    <main class="products-main">
      <h1 class="page-title">
        Products {activeCategories.length > 0 ? `(${filteredProducts.length})` : ''}
      </h1>
      <div class="products-grid">
        {filteredProducts.map(p => {
          const img = getFirstImage(p);
          return (
            <a href={`/productss/${p.slug}`} class="product-card">
              <div class="product-image">
                {img
                  ? <img src={img} alt={p.data?.title || ''} loading="lazy" />
                  : <div class="no-image">No Image</div>}
              </div>
              <h3 class="product-name">{p.data?.title}</h3>
            </a>
          );
        })}
      </div>
      {filteredProducts.length === 0 && (
        <div class="empty">No products found</div>
      )}
    </main>
  </div>

  <script is:inline>
    function toggle(slug) {
      const u = new URL(location.href);
      const c = u.searchParams.getAll('category');
      if (c.includes(slug)) {
        u.searchParams.delete('category');
        c.filter(x => x !== slug).forEach(x => u.searchParams.append('category', x));
      } else {
        u.searchParams.append('category', slug);
      }
      location.href = u.toString();
    }
  </script>
</Base>

<style>
  /* ===== 布局 ===== */
  .products-page {
    max-width: 1400px; margin: 0 auto; padding: 2rem;
    display: grid; grid-template-columns: 260px 1fr; gap: 3rem; align-items: start;
  }
  .filter-sidebar { position: sticky; top: 2rem; height: fit-content; }

  /* ===== 顶部入口 ===== */
  .top-entries {
    border-bottom: 1px solid #e0e0e0; padding-bottom: 0.75rem; margin-bottom: 0.75rem;
  }
  .top-item {
    display: flex; align-items: center; gap: 0.6rem;
    padding: 0.5rem 0.25rem; cursor: pointer; font-size: 0.9rem;
    color: #555; text-decoration: none; border-radius: 4px;
    transition: all 0.15s;
  }
  .top-item:hover { background: #f5f5f5; color: #000; }
  .top-item.active { color: #000; font-weight: 600; }
  .top-item input { width: 16px; height: 16px; flex-shrink: 0; cursor: pointer; }
  .top-item .count { color: #999; font-size: 0.8rem; margin-left: auto; }

  /* ===== 分类组 ===== */
  .category-block { padding: 0.75rem 0; border-bottom: 1px solid #e0e0e0; }
  .cat-title {
    display: block; font-size: 0.95rem; font-weight: 700; color: #222;
    padding: 0.5rem 0.25rem; margin-bottom: 0.5rem;
  }
  .cat-items { padding-left: 0.5rem; }
  .cat-item {
    display: flex; align-items: center; gap: 0.6rem;
    padding: 0.4rem 0.25rem; cursor: pointer; font-size: 0.88rem;
    color: #555; border-radius: 4px; transition: all 0.15s;
  }
  .cat-item:hover { background: #f5f5f5; color: #000; }
  .cat-item.active { color: #000; font-weight: 500; }
  .cat-item input { width: 16px; height: 16px; flex-shrink: 0; cursor: pointer; }
  .cat-item .count { color: #999; font-size: 0.8rem; margin-left: auto; }

  /* ===== 产品网格 ===== */
  .products-main { min-height: 600px; }
  .page-title { font-size: 1.5rem; font-weight: 600; margin-bottom: 1.5rem; color: #333; }
  .products-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem; }
  .product-card {
    text-decoration: none; color: inherit; border-radius: 8px; overflow: hidden;
    background: #fff; border: 1px solid #f0f0f0;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .product-card:hover { transform: translateY(-4px); box-shadow: 0 8px 24px rgba(0,0,0,0.08); }
  .product-image {
    aspect-ratio: 1; background: #f8f9fa; overflow: hidden;
    display: flex; align-items: center; justify-content: center;
  }
  .product-image img {
    width: 100%; height: 100%; object-fit: contain; padding: 1rem;
    transition: transform 0.3s;
  }
  .product-card:hover .product-image img { transform: scale(1.03); }
  .no-image { color: #bbb; font-size: 0.9rem; }
  .product-name {
    font-size: 0.9rem; font-weight: 500; line-height: 1.4; color: #333;
    padding: 0.75rem; display: -webkit-box; -webkit-line-clamp: 2;
    -webkit-box-orient: vertical; overflow: hidden; min-height: 3.2em;
  }
  .empty { text-align: center; padding: 5rem 2rem; color: #999; }

  @media (max-width: 1200px) { .products-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 900px) {
    .products-page { grid-template-columns: 1fr; gap: 2rem; }
    .filter-sidebar { position: static; }
    .products-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 500px) { .products-grid { grid-template-columns: repeat(2, 1fr); gap: 1rem; } }
</style>
