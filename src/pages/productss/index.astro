---
import { getEmDashCollection } from "emdash";
import Base from "../../layouts/Base.astro";

const { entries } = await getEmDashCollection("productss");

const categoryTree = [
  {
    slug: "company-news",
    name: "Company News",
    children: [
      {
        slug: "company-industry",
        name: "Industry Trends",
        children: [
          { slug: "ai-technology", name: "AI Technology" },
          { slug: "market-analysis", name: "Market Analysis" }
        ]
      },
      {
        slug: "company-events",
        name: "Company Events",
        children: [
          { slug: "annual-meeting", name: "Annual Meeting" },
          { slug: "company-corporates", name: "Company Corporates" },
          { slug: "company-milestones", name: "Company Milestones" },
          { slug: "team-building", name: "Team Building" },
          { slug: "test-news", name: "Test News" }
        ]
      }
    ]
  }
];

// 递归收集所有有子类的节点（每个独立做一个列表）
function collectSections(tree) {
  const sections = [];
  tree.forEach(node => {
    if (node.children && node.children.length > 0) {
      sections.push({ slug: node.slug, name: node.name, children: node.children.map(c => c.slug) });
      sections.push(...collectSections(node.children));
    }
  });
  return sections;
}
const categorySections = collectSections(categoryTree);

// 扁平收集所有节点名（用于 slug → name 映射）
function flattenNames(tree) {
  const map = new Map();
  tree.forEach(n => {
    map.set(n.slug, n.name);
    if (n.children) flattenNames(n.children).forEach((v, k) => map.set(k, v));
  });
  return map;
}
const slugNames = flattenNames(categoryTree);

// 统计每个分类的产品数量
const categoryCounts = new Map();
entries?.forEach(entry => {
  const terms = entry.terms?.product || [];
  terms.forEach(term => {
    const slug = term.slug;
    categoryCounts.set(slug, (categoryCounts.get(slug) || 0) + 1);
  });
});

const url = new URL(Astro.request.url);
const selectedCategories = url.searchParams.getAll("category");

const filteredProducts = selectedCategories.length > 0
  ? entries?.filter(e => {
      const productTerms = e.terms?.product?.map(t => t.slug) || [];
      return selectedCategories.some(cat => productTerms.includes(cat));
    })
  : entries;

function getFirstImage(entry) {
  try {
    if (!entry.data?.picture_json) return '';
    const raw = typeof entry.data.picture_json === 'string' ? entry.data.picture_json : JSON.stringify(entry.data.picture_json);
    if (!raw || raw === 'null' || raw === '{}') return '';
    const parsed = JSON.parse(raw);
    const pics = Array.isArray(parsed) ? parsed : [parsed];
    if (!pics[0]) return '';
    return pics[0]?.url || pics[0]?.src || (typeof pics[0] === 'string' ? pics[0] : '');
  } catch (e) { return ''; }
}

function isActive(slug) { return selectedCategories.includes(slug); }
---

<Base title="Products">
  <!-- 调试：查看实际 slug -->
  <div style="background:#ff0;padding:8px 12px;font-size:12px;font-family:monospace;line-height:1.6;">
    Actual slugs from products: {JSON.stringify(Array.from(categoryCounts.keys()))}
  </div>

  <div class="products-page">
    <aside class="filter-sidebar">
      <div class="filter-section all-products-section">
        <a href="/productss" class={`filter-item all-products ${selectedCategories.length === 0 ? 'active' : ''}`}>
          <input type="checkbox" checked={selectedCategories.length === 0} />
          <span>All Products</span>
        </a>
      </div>

      {categorySections.map(section => (
        <div class="category-block">
          <span class="section-title">{section.name}</span>
          <div class="section-items">
            {section.children.map(childSlug => {
              const childName = slugNames.get(childSlug) || childSlug;
              const count = categoryCounts.get(childSlug) || 0;
              return (
                <label class={`filter-item ${isActive(childSlug) ? 'active' : ''}`}>
                  <input type="checkbox" checked={isActive(childSlug)} onchange={`toggleCategory('${childSlug}')`} />
                  <span>{childName}</span>
                  <span class="count">({count})</span>
                </label>
              );
            })}
          </div>
        </div>
      ))}
    </aside>

    <main class="products-main">
      <h1 class="page-title">Products {selectedCategories.length > 0 && filteredProducts ? `(${filteredProducts.length})` : ''}</h1>
      <div class="products-grid">
        {filteredProducts?.map(product => {
          const imgUrl = getFirstImage(product);
          return (
            <a href={`/productss/${product.slug}`} class="product-card">
              <div class="product-image">
                {imgUrl ? <img src={imgUrl} alt={product.data?.title || ''} loading="lazy" /> : <div class="no-image">No Image</div>}
              </div>
              <h3 class="product-title">{product.data?.title}</h3>
            </a>
          );
        })}
      </div>
      {(!filteredProducts || filteredProducts.length === 0) && <div class="empty-state"><p>No products found</p></div>}
    </main>
  </div>

  <script is:inline>
    function toggleCategory(slug) {
      const url = new URL(location.href);
      const current = url.searchParams.getAll('category');
      if (current.includes(slug)) { url.searchParams.delete('category'); current.filter(c => c !== slug).forEach(c => url.searchParams.append('category', c)); }
      else { url.searchParams.append('category', slug); }
      location.href = url.toString();
    }
  </script>
</Base>

<style>
  .products-page { max-width: 1400px; margin: 0 auto; padding: 2rem; display: grid; grid-template-columns: 260px 1fr; gap: 3rem; align-items: start; }
  .filter-sidebar { position: sticky; top: 2rem; height: fit-content; }
  .all-products-section { padding: 0.75rem 0; border-bottom: 1px solid #e0e0e0; margin-bottom: 0.5rem; }
  .category-block { padding: 0.75rem 0; border-bottom: 1px solid #e0e0e0; }
  .section-title { display: block; font-size: 0.95rem; font-weight: 700; color: #222; padding: 0.5rem 0.25rem; margin-bottom: 0.5rem; }
  .section-items { padding-left: 0.5rem; }
  .filter-item { display: flex; align-items: center; gap: 0.6rem; padding: 0.4rem 0.25rem; cursor: pointer; font-size: 0.88rem; color: #555; text-decoration: none; transition: all 0.15s; border-radius: 4px; }
  .filter-item:hover { background: #f5f5f5; color: #000; }
  .filter-item.active { color: #000; font-weight: 500; }
  .filter-item.all-products { font-weight: 600; font-size: 0.9rem; }
  .filter-item input[type="checkbox"] { width: 16px; height: 16px; cursor: pointer; flex-shrink: 0; }
  .count { color: #999; font-size: 0.8rem; margin-left: auto; }
  .products-main { min-height: 600px; }
  .page-title { font-size: 1.5rem; font-weight: 600; margin-bottom: 1.5rem; color: #333; }
  .products-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem; }
  .product-card { text-decoration: none; color: inherit; transition: transform 0.2s, box-shadow 0.2s; border-radius: 8px; overflow: hidden; background: #fff; border: 1px solid #f0f0f0; }
  .product-card:hover { transform: translateY(-4px); box-shadow: 0 8px 24px rgba(0,0,0,0.08); }
  .product-image { aspect-ratio: 1; background: #f8f9fa; overflow: hidden; display: flex; align-items: center; justify-content: center; }
  .product-image img { width: 100%; height: 100%; object-fit: contain; padding: 1rem; transition: transform 0.3s; }
  .product-card:hover .product-image img { transform: scale(1.03); }
  .no-image { color: #bbb; font-size: 0.9rem; }
  .product-title { font-size: 0.9rem; font-weight: 500; line-height: 1.4; color: #333; padding: 0.75rem; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; min-height: 3.2em; }
  .empty-state { text-align: center; padding: 5rem 2rem; color: #999; }
  @media (max-width: 1200px) { .products-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 900px) { .products-page { grid-template-columns: 1fr; gap: 2rem; } .filter-sidebar { position: static; } .products-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 500px) { .products-grid { grid-template-columns: repeat(2, 1fr); gap: 1rem; } }
</style>
