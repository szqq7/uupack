---
import { getEmDashEntry } from "emdash";
import { PortableText } from "emdash/ui";
import Base from "../../layouts/Base.astro";

const { entry, cacheHint } = await getEmDashEntry("productss", Astro.params.slug);

if (!entry) return Astro.redirect("/404");
if (Astro.cache?.enabled) Astro.cache.set(cacheHint);

const data = entry.data || {};
const title = data.title || "Untitled";

const SKIP = new Set([
  'title', 'id', 'slug', 'status', 'createdAt', 'updatedAt',
  'publishedAt', 'terms', 'bylines', 'authorId', 'liveRevisionId',
  'published_at', 'featured_image', 'excerpt', 'seo'
]);

interface Field {
  key: string;
  label: string;
  type: 'table' | 'portable' | 'json' | 'text' | 'plain';
  value: any;
}

const fields: Field[] = [];

for (const [key, value] of Object.entries(data)) {
  if (SKIP.has(key)) continue;
  if (value === null || value === undefined || value === '') continue;
  
  const label = key.replace(/_/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase());
  
  if (key === 'item_details' && typeof value === 'string') {
    try {
      const rows = JSON.parse(value);
      if (Array.isArray(rows)) {
        fields.push({ key, label, type: 'table', value: rows });
        continue;
      }
    } catch {}
  }
  
  if (typeof value === 'object') {
    fields.push({ key, label, type: 'portable', value });
    continue;
  }
  
  if (typeof value === 'string' && (value.startsWith('[') || value.startsWith('{'))) {
    try {
      fields.push({ key, label, type: 'json', value: JSON.parse(value) });
      continue;
    } catch {}
  }
  
  fields.push({ key, label, type: 'text', value: String(value) });
}
---

<Base title={title}>
  <article class="article">
    <div class="article-main">
      <header class="article-header">
        <h1 class="article-title">{title}</h1>
      </header>
      <div class="article-content">
        {fields.map((f) => {
          if (f.type === 'table') return (
            <section class="field-section">
              <h2>{f.label}</h2>
              <table class="data-table">
                <tbody>
                  {f.value.map((r: any, i: number) => (
                    <tr>
                      <td class="tc1">{r.key || r.label || i + 1}</td>
                      <td class="tc2">{r.value || String(r)}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </section>
          );
          if (f.type === 'portable') return (
            <section class="field-section">
              <h2>{f.label}</h2>
              <PortableText value={f.value} />
            </section>
          );
          if (f.type === 'json') return (
            <section class="field-section">
              <h2>{f.label}</h2>
              <pre class="json-box">{JSON.stringify(f.value, null, 2)}</pre>
            </section>
          );
          return (
            <section class="field-section">
              <h2>{f.label}</h2>
              <p>{f.value}</p>
            </section>
          );
        })}
      </div>
    </div>
  </article>
</Base>

<style>
  .article-title { font-size: 2.5rem; font-weight: 700; margin-bottom: 1.5rem; }
  .field-section { margin-bottom: 2rem; padding-bottom: 1.5rem; border-bottom: 1px solid #eee; }
  .field-section h2 { font-size: 1.2rem; font-weight: 600; margin-bottom: 0.8rem; color: #333; }
  .data-table { width: 100%; border-collapse: collapse; }
  .data-table td { padding: 0.6rem 0.8rem; border-bottom: 1px solid #f0f0f0; }
  .tc1 { font-weight: 600; width: 30%; color: #555; background: #f9f9f9; }
  .tc2 { color: #222; }
  .json-box { background: #f5f5f5; padding: 1rem; border-radius: 4px; overflow-x: auto; font-size: 0.85rem; }
</style>
