---
import { getEmDashEntry, getEmDashCollection } from "emdash";
import Base from "../../layouts/Base.astro";

const { slug } = Astro.params;

const full = await getEmDashEntry("productss", slug);
const p = full || {};
const data = p?.data || {};

const { entries: allEntries } = await getEmDashCollection("productss");
const allProducts = (allEntries || []).filter((e) => e.slug !== slug);

const productTerms = (p?.terms?.product || []).map((t: any) =>
  typeof t === "string" ? t : t?.slug
).filter(Boolean);

function parseJsonField(raw) {
  if (!raw) return null;
  try {
    return typeof raw === "string" ? JSON.parse(raw) : raw;
  } catch { return null; }
}

const pictureData = parseJsonField(data.picture_json);
let mainImage = "";
const picList = Array.isArray(pictureData) ? pictureData : (pictureData ? [pictureData] : []);
if (picList.length > 0) {
  const first = picList[0];
  mainImage = first?.url || first?.src || (typeof first === "string" ? first : "");
}

const colorData = parseJsonField(data.color_img);
let colorImages = [];
if (colorData) {
  const list = Array.isArray(colorData) ? colorData : [colorData];
  colorImages = list.map((c) => c?.url || c?.src || (typeof c === "string" ? c : "")).filter(Boolean);
}

const topHighlights = data.top_highlights || data.topHighlights || "";

const itemDetails = parseJsonField(data.item_details);
let detailsTable = [];
if (Array.isArray(itemDetails)) {
  detailsTable = itemDetails;
} else if (itemDetails && typeof itemDetails === "object") {
  detailsTable = Object.entries(itemDetails).map(([k, v]) => ({ label: k, value: v }));
}

function renderMarkdownSimple(md) {
  if (!md) return "";
  const escape = (s) => s.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
  let html = escape(md);
  html = html.replace(/^### (.+)$/gm, "<h3>$1</h3>");
  html = html.replace(/^## (.+)$/gm, "<h2>$1</h2>");
  html = html.replace(/\*\*(.+?)\*\*/g, "<strong>$1</strong>");
  html = html.replace(/\*(.+?)\*/g, "<em>$1</em>");
  html = html.replace(/^- (.+)$/gm, "<li>$1</li>");
  html = html.replace(/(<li>.*<\/li>\n?)+/g, (m) => "<ul>" + m + "</ul>");
  html = html.split(/\n{2,}/).map((p) => {
    if (p.startsWith("<h") || p.startsWith("<ul>")) return p;
    return "<p>" + p.replace(/\n/g, "<br>") + "</p>";
  }).join("\n");
  return html;
}

let related = [];
if (productTerms.length > 0 && allProducts.length > 0) {
  const relatedWithTerms = await Promise.all(
    allProducts.map(async (e) => {
      try {
        const f = await getEmDashEntry("productss", e.slug);
        const terms = (f?.terms?.product || []).map((t: any) =>
          typeof t === "string" ? t : t?.slug
        );
        return { entry: e, terms };
      } catch { return { entry: e, terms: [] }; }
    })
  );
  related = relatedWithTerms
    .filter((r: any) => r.terms.some((t: string) => productTerms.includes(t)))
    .slice(0, 4)
    .map((r: any) => r.entry);
}
---

<Base title={data.title || slug} description={data.description || ""}>
  <article class="product-detail">
    <div class="gallery">
      {mainImage ? (
        <div class="main-image">
          <img src={mainImage} alt={data.title || ""} />
        </div>
      ) : (
        <div class="main-image no-image">No Image</div>
      )}

      {picList.length > 1 && (
        <div class="thumb-list">
          {picList.slice(0, 5).map((pic, i) => {
            const url = pic?.url || pic?.src || (typeof pic === "string" ? pic : "");
            if (!url) return null;
            return <img src={url} alt={`${data.title} ${i+1}`} class="thumb" />;
          })}
        </div>
      )}

      {colorImages.length > 0 && (
        <div class="color-list">
          <div class="color-label">Color Options</div>
          <div class="color-thumbs">
            {colorImages.map((url) => (
              <img src={url} alt="" class="color-thumb" />
            ))}
          </div>
        </div>
      )}
    </div>

    <div class="info">
      <h1 class="title">{data.title || "未命名产品"}</h1>

      {data.spu && (
        <div class="meta">
          <span class="meta-label">Code:</span>
          <code class="meta-value">{data.spu}</code>
        </div>
      )}

      {productTerms.length > 0 && (
        <div class="breadcrumb-cats">
          {productTerms.map((t: string) => (
            <a href={`/productss?category=${t}`} class="cat-pill">{t}</a>
          ))}
        </div>
      )}

      {topHighlights && (
        <section class="section">
          <h2 class="section-title">Top Highlights</h2>
          <div class="markdown" set:html={renderMarkdownSimple(topHighlights)} />
        </section>
      )}

      {detailsTable.length > 0 && (
        <section class="section">
          <h2 class="section-title">Item Details</h2>
          <table class="details-table">
            <tbody>
              {detailsTable.map((row) => (
                <tr>
                  <th>{row.label || row.name || row.key || ""}</th>
                  <td>{row.value || row.val || ""}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </section>
      )}
    </div>
  </article>

  {related.length > 0 && (
    <section class="related">
      <h2 class="related-title">Related Products</h2>
      <div class="related-grid">
        {related.map((r) => {
          const rpic = parseJsonField(r.data?.picture_json);
          const rlist = Array.isArray(rpic) ? rpic : (rpic ? [rpic] : []);
          const rimg = rlist[0]?.url || rlist[0]?.src || "";
          return (
            <a href={`/productss/${r.slug}`} class="related-card">
              {rimg ? <img src={rimg} alt={r.data?.title || ""} /> : <div class="no-image">No Image</div>}
              <h3>{r.data?.title}</h3>
            </a>
          );
        })}
      </div>
    </section>
  )}
</Base>

<style>
  .product-detail {
    max-width: 1280px; margin: 2rem auto; padding: 0 2rem;
    display: grid; grid-template-columns: minmax(0, 1fr) minmax(0, 1.2fr);
    gap: 3rem; align-items: start;
  }
  .gallery { position: sticky; top: 2rem; }
  .main-image {
    aspect-ratio: 1; background: #fafafa; border: 1px solid #eee; border-radius: 12px;
    overflow: hidden; display: flex; align-items: center; justify-content: center;
  }
  .main-image img { width: 100%; height: 100%; object-fit: contain; padding: 1.5rem; }
  .main-image.no-image { color: #999; }
  .thumb-list { display: flex; gap: 0.5rem; margin-top: 0.75rem; flex-wrap: wrap; }
  .thumb { width: 60px; height: 60px; object-fit: contain; border: 1px solid #eee; border-radius: 6px; background: #fafafa; padding: 4px; cursor: pointer; }
  .color-list { margin-top: 1rem; }
  .color-label { font-size: 0.85rem; color: #666; margin-bottom: 0.5rem; }
  .color-thumbs { display: flex; gap: 0.5rem; flex-wrap: wrap; }
  .color-thumb { width: 50px; height: 50px; object-fit: cover; border: 1px solid #eee; border-radius: 6px; }

  .info { min-width: 0; }
  .title { font-size: 1.75rem; font-weight: 700; color: #1a1a1a; margin: 0 0 0.75rem; line-height: 1.3; }
  .meta { display: flex; gap: 0.5rem; align-items: center; margin-bottom: 1rem; font-size: 0.9rem; }
  .meta-label { color: #666; }
  .meta-value { background: #f0f0f0; padding: 2px 8px; border-radius: 4px; font-size: 0.85rem; }
  .breadcrumb-cats { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 1.5rem; }
  .cat-pill {
    background: #f0f6ff; color: #06c; font-size: 0.8rem;
    padding: 4px 10px; border-radius: 12px; text-decoration: none;
  }
  .cat-pill:hover { background: #06c; color: #fff; }

  .section { margin-top: 2rem; }
  .section-title { font-size: 1.1rem; font-weight: 600; color: #1a1a1a; margin: 0 0 1rem; padding-bottom: 0.5rem; border-bottom: 1px solid #eee; }
  .markdown { font-size: 0.95rem; line-height: 1.7; color: #333; }
  .markdown h1, .markdown h2, .markdown h3 { margin: 1rem 0 0.5rem; font-weight: 600; }
  .markdown p { margin: 0.5rem 0; }
  .markdown ul, .markdown ol { margin: 0.5rem 0; padding-left: 1.5rem; }
  .markdown strong { font-weight: 700; color: #000; }

  .details-table { width: 100%; border-collapse: collapse; font-size: 0.9rem; }
  .details-table th, .details-table td { padding: 0.6rem 0.75rem; border: 1px solid #eee; text-align: left; }
  .details-table th { background: #f8f8f8; font-weight: 600; color: #555; width: 30%; }

  .related { max-width: 1280px; margin: 3rem auto; padding: 0 2rem; }
  .related-title { font-size: 1.25rem; font-weight: 600; color: #1a1a1a; margin-bottom: 1.25rem; }
  .related-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.25rem; }
  .related-card { text-decoration: none; color: inherit; border: 1px solid #eee; border-radius: 8px; overflow: hidden; transition: all 0.2s; }
  .related-card:hover { transform: translateY(-3px); box-shadow: 0 6px 20px rgba(0,0,0,0.08); }
  .related-card img { width: 100%; aspect-ratio: 1; object-fit: contain; padding: 1rem; background: #fafafa; }
  .related-card h3 { font-size: 0.85rem; font-weight: 500; margin: 0; padding: 0.75rem; line-height: 1.4; }

  @media (max-width: 900px) {
    .product-detail { grid-template-columns: 1fr; gap: 1.5rem; }
    .gallery { position: static; }
    .related-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>
